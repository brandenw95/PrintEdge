        {
          "id": "local-mfp-01",
          "displayName": "Local Test MFP",
          "hostAddress": "10.0.1.50",
          "location": "Local Office",
          "defaultDriverName": "Microsoft IPP Class Driver",
          "infPath": "",
          "driverBlobPath": "sample/local-mfp-driver.zip",
          "infRelativePath": "x64/sample.inf"
        },
        {
          "id": "local-label-01",
          "displayName": "Local Test Labels",
