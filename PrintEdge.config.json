{
  "settings": {
    "pollIntervalSeconds": 30,
    "managedNamePrefix": "PrintEdge - ",
    "prefixQueueNames": true,
    "removeStaleManagedQueues": true,
    "removeUnmanagedPrinters": false,
    "dryRun": false,
    "driverCachePath": "Drivers",
    "logPath": "%ProgramData%\\PrintEdge\\Logs\\PrintEdge.log",
    "enableAzureDriverDownload": false,
    "azureBlobBaseUrl": "https://contoso-print-drivers.blob.core.windows.net/drivers",
    "azureSasToken": ""
  },
  "subnets": [
    {
      "name": "Local Test Network",
      "cidr": "10.0.1.0/24",
